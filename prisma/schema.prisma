generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Article {
  id               String   @id @default(cuid())
  title            String
  slug             String   @unique
  content          String   @db.Text
  contentRaw       String?  @db.Text
  excerpt          String?  @db.Text
  coverImage       String?
  published        Boolean  @default(true)
  isDisambiguation Boolean  @default(false)
  redirectTo       String?
  infobox          Json?
  categoryId       String?
  category         Category? @relation(fields: [categoryId], references: [id])
  tags             ArticleTag[]
  mapMarkers       MapMarker[]
  revisions        ArticleRevision[]
  discussions      Discussion[]
  translations     ArticleTranslation[]
  outgoingLinks    ArticleLink[] @relation("OutgoingLinks")
  watchedBy        Watchlist[]
  notifications    Notification[]

  // Phase 2 additions
  sortOrder        Int      @default(0)
  status           String   @default("published") // "draft", "review", "published"
  isPinned         Boolean  @default(false)
  userId           String?
  user             User?    @relation(fields: [userId], references: [id])

  // v3.0 additions
  publishAt        DateTime?
  archivedAt       DateTime?
  wikiId           String?
  wiki             Wiki?    @relation(fields: [wikiId], references: [id])

  reviews          ReviewRequest[]
  changeRequests   ChangeRequest[]
  activityEvents   ActivityEvent[]

  // v4.0 additions
  summary          String?  @db.Text
  summaryShort     String?

  embedding        ArticleEmbedding?

  // v4.1 additions
  learningPaths    LearningPathArticle[]
  flashcards       Flashcard[]
  quizAttempts     QuizAttempt[]
  reads            ArticleRead[]

  // v4.3 additions
  bookmarks        Bookmark[]
  readingListItems ReadingListItem[]
  tilPosts         TILPost[]

  // v4.4 additions
  certified        Boolean  @default(false)
  certifiedAt      DateTime?
  forks            ArticleFork[]
  reactions        ArticleReaction[]
  bounties         KnowledgeBounty[]

  // v4.5 additions
  issueLinks       IssueLink[]
  embedTokens      EmbedToken[]

  // v4.6 additions
  scrollDepthLogs  ScrollDepthLog[]

  // v4.7 additions
  dir              String   @default("ltr")  // "ltr" | "rtl"

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([slug])
  @@index([categoryId])
  @@index([status])
  @@index([userId])
  @@index([wikiId])
}

model Category {
  id          String     @id @default(cuid())
  name        String     @unique
  slug        String     @unique
  description String?
  sortOrder   Int        @default(0)
  parentId     String?
  parent       Category?   @relation("CategoryTree", fields: [parentId], references: [id])
  children     Category[]  @relation("CategoryTree")
  articles     Article[]
  expertBadges ExpertBadge[]
  createdAt    DateTime    @default(now())

  @@index([parentId])
}

model Tag {
  id       String       @id @default(cuid())
  name     String       @unique
  slug     String       @unique
  color    String?
  parentId String?
  parent   Tag?         @relation("TagTree", fields: [parentId], references: [id])
  children Tag[]        @relation("TagTree")
  articles ArticleTag[]

  @@index([parentId])
}

model ArticleTag {
  articleId String
  tagId     String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
  @@index([tagId])
}

model ArticleRevision {
  id          String   @id @default(cuid())
  articleId   String
  article     Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  content     String   @db.Text
  contentRaw  String?  @db.Text
  title       String
  infobox     Json?
  editSummary String?
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())

  @@index([articleId])
  @@index([createdAt])
  @@index([userId])
}

model Discussion {
  id        String       @id @default(cuid())
  articleId String
  article   Article      @relation(fields: [articleId], references: [id], onDelete: Cascade)
  author    String       @default("Anonymous")
  content   String       @db.Text
  userId    String?
  user      User?        @relation(fields: [userId], references: [id])
  parentId  String?
  parent    Discussion?  @relation("Replies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Discussion[] @relation("Replies")
  createdAt DateTime     @default(now())

  @@index([articleId])
  @@index([createdAt])
  @@index([parentId])
}

model MapMarker {
  id        String   @id @default(cuid())
  label     String
  polygon   Json
  color     String?
  mapId     String   @default("default")
  articleId String?
  article   Article? @relation(fields: [articleId], references: [id], onDelete: SetNull)
  minZoom   Float?
  maxZoom   Float?
  createdAt DateTime @default(now())

  @@index([mapId])
}

// ── Multi-language support ──
model ArticleTranslation {
  id         String   @id @default(cuid())
  articleId  String
  article    Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  locale     String   // e.g. "en", "fr", "ar"
  title      String
  content    String   @db.Text
  contentRaw String?  @db.Text
  excerpt    String?  @db.Text
  updatedAt  DateTime @updatedAt

  @@unique([articleId, locale])
  @@index([articleId])
  @@index([locale])
}

// ── User system ──
model User {
  id           String    @id @default(cuid())
  username     String    @unique
  email        String    @unique
  passwordHash String
  displayName  String?
  role         String    @default("viewer") // "admin", "editor", "viewer"
  articles        Article[]
  revisions       ArticleRevision[]
  discussions     Discussion[]
  sessions        Session[]
  watchlist       Watchlist[]
  notifications   Notification[]
  apiKeys         ApiKey[]

  // v3.0 additions
  savedSearches    SavedSearch[]
  searchHistory    SearchHistory[]
  preferences      UserPreference?
  oauthAccounts    OAuthAccount[]
  reviewsAuthored  ReviewRequest[]   @relation("ReviewAuthor")
  reviewsAssigned  ReviewRequest[]   @relation("ReviewAssigned")
  reviewComments   ReviewComment[]
  changeRequests   ChangeRequest[]
  activityEvents   ActivityEvent[]
  permissionGrants PermissionGrant[]
  themeConfigs     ThemeConfig[]
  ownedWikis       Wiki[]
  wikiMemberships  WikiMembership[]

  // v4.1 additions
  learningPaths    LearningPath[]
  learningProgress LearningPathProgress[]
  flashcards       Flashcard[]
  quizAttempts     QuizAttempt[]
  articleReads     ArticleRead[]

  // v4.3 additions
  smartCollections SmartCollection[]
  bookmarks        Bookmark[]
  readingLists     ReadingList[]
  tilPosts         TILPost[]

  // v4.4 additions
  expertBadges     ExpertBadge[]
  bountiesRequested KnowledgeBounty[] @relation("BountiesRequested")
  bountiesClaimed  KnowledgeBounty[] @relation("BountiesClaimed")
  forks            ArticleFork[]
  reactions        ArticleReaction[]

  // v4.6 additions
  achievements     ContributorAchievement[]

  // v4.9 additions
  scratchpad       Scratchpad?

  createdAt    DateTime  @default(now())

  @@index([role])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

// ── Watchlist & Notifications ──
model Watchlist {
  userId    String
  articleId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, articleId])
  @@index([userId])
  @@index([articleId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  articleId String?
  article   Article? @relation(fields: [articleId], references: [id], onDelete: Cascade)
  type      String   // "edit", "reply", "mention"
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([articleId])
}

// ── Public API ──
model ApiKey {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  key        String   @unique
  name       String
  lastUsedAt DateTime?
  createdAt  DateTime @default(now())

  @@index([key])
  @@index([userId])
}

// ── Webhooks ──
model Webhook {
  id         String   @id @default(cuid())
  url        String
  events     String[] // ["article.created", "article.updated", "article.deleted"]
  secret     String?
  active     Boolean  @default(true)
  deliveries WebhookDelivery[]
  createdAt  DateTime @default(now())
}

model WebhookDelivery {
  id           String   @id @default(cuid())
  webhookId    String
  webhook      Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  event        String
  payload      Json
  status       String   // "success", "failed"
  responseCode Int?
  createdAt    DateTime @default(now())

  @@index([webhookId])
  @@index([createdAt])
}

// ── Semantic wiki links ──
model ArticleLink {
  id         String   @id @default(cuid())
  sourceId   String
  targetSlug String
  relation   String   @default("related-to")
  source     Article  @relation("OutgoingLinks", fields: [sourceId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([sourceId, targetSlug, relation])
  @@index([sourceId])
  @@index([targetSlug])
  @@index([relation])
}

// ── Plugin system ──
model PluginState {
  id        String   @id // Plugin ID from manifest
  enabled   Boolean  @default(false)
  config    Json?
  updatedAt DateTime @updatedAt
}

// ── Performance monitoring ──
model MetricLog {
  id        String   @id @default(cuid())
  type      String   // "api_request", "page_view", "error"
  path      String
  duration  Int      // milliseconds
  status    Int?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([type])
  @@index([createdAt])
  @@index([path])
}

// ── Map system ──
model MapConfig {
  id          String   @id @default(cuid())
  mapId       String   @unique
  name        String
  description String?
  imageUrl    String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([sortOrder])
}

model MapLayer {
  id        String   @id @default(cuid())
  mapId     String
  name      String
  imageUrl  String
  opacity   Float    @default(0.7)
  sortOrder Int      @default(0)
  visible   Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([mapId])
}

model MapDetailLevel {
  id       String @id @default(cuid())
  mapId    String
  minZoom  Float
  maxZoom  Float
  imageUrl String
  bounds   Json   // [[y1,x1],[y2,x2]]

  @@index([mapId])
}

// ── Collaboration ──
model CollaborationSession {
  id        String   @id @default(cuid())
  articleId String   @unique
  ydoc      Bytes
  updatedAt DateTime @updatedAt

  @@index([articleId])
}

// ── v3.0: Search ──
model SavedSearch {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  query     String
  filters   Json?
  createdAt DateTime @default(now())

  @@index([userId])
}

model SearchHistory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  query     String
  filters   Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// ── v3.0: User Preferences ──
model UserPreference {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  data   Json   // { dashboardWidgets, editorMode, notifications, locale, theme, etc. }

  @@index([userId])
}

// ── v3.0: Review Workflow ──
model ReviewRequest {
  id          String   @id @default(cuid())
  articleId   String
  article     Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  authorId    String
  author      User     @relation("ReviewAuthor", fields: [authorId], references: [id])
  reviewerId  String?
  reviewer    User?    @relation("ReviewAssigned", fields: [reviewerId], references: [id])
  status      String   @default("pending") // "pending", "in_review", "approved", "changes_requested", "rejected"
  message     String?  @db.Text
  comments    ReviewComment[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([articleId])
  @@index([authorId])
  @@index([reviewerId])
  @@index([status])
}

model ReviewComment {
  id              String        @id @default(cuid())
  reviewRequestId String
  reviewRequest   ReviewRequest @relation(fields: [reviewRequestId], references: [id], onDelete: Cascade)
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  content         String        @db.Text
  selector        String?       // JSON: text range for inline comments
  resolved        Boolean       @default(false)
  createdAt       DateTime      @default(now())

  @@index([reviewRequestId])
  @@index([userId])
}

// ── v3.0: Change Requests ──
model ChangeRequest {
  id          String   @id @default(cuid())
  articleId   String
  article     Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  title       String
  description String?  @db.Text
  content     String   @db.Text
  status      String   @default("open") // "open", "accepted", "rejected", "withdrawn"
  reviewedBy  String?
  reviewNote  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([articleId])
  @@index([authorId])
  @@index([status])
}

// ── v3.0: Activity Feed ──
model ActivityEvent {
  id        String   @id @default(cuid())
  type      String   // "article_created", "article_edited", "article_published", etc.
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  articleId String?
  article   Article? @relation(fields: [articleId], references: [id], onDelete: SetNull)
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([type])
  @@index([userId])
  @@index([articleId])
  @@index([createdAt])
}

// ── v3.0: OAuth ──
model OAuthAccount {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          String   // "google", "github"
  providerAccountId String
  accessToken       String?  @db.Text
  refreshToken      String?  @db.Text
  expiresAt         Int?
  createdAt         DateTime @default(now())

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// ── v3.0: Fine-grained RBAC ──
model PermissionGrant {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resourceType String   // "category", "article"
  resourceId   String
  permission   String   // "view", "edit", "admin"
  createdAt    DateTime @default(now())

  @@unique([userId, resourceType, resourceId, permission])
  @@index([userId])
  @@index([resourceType, resourceId])
}

// ── v3.0: Theme Builder ──
model ThemeConfig {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  variables Json     // CSS variable overrides
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ── v3.0: Multi-Wiki ──
model Wiki {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  settings    Json?
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id])
  articles    Article[]
  memberships WikiMembership[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([ownerId])
}

model WikiMembership {
  id     String @id @default(cuid())
  wikiId String
  wiki   Wiki   @relation(fields: [wikiId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   String @default("viewer") // "admin", "editor", "viewer"

  @@unique([wikiId, userId])
  @@index([wikiId])
  @@index([userId])
}

// ── v4.1: Learning & Retention ──
model LearningPath {
  id          String                @id @default(cuid())
  name        String
  description String?               @db.Text
  authorId    String?
  isPublic    Boolean               @default(true)
  articles    LearningPathArticle[]
  progress    LearningPathProgress[]
  createdAt   DateTime              @default(now())
  author      User?                 @relation(fields: [authorId], references: [id])

  @@index([authorId])
}

model LearningPathArticle {
  id        String       @id @default(cuid())
  pathId    String
  articleId String
  order     Int
  path      LearningPath @relation(fields: [pathId], references: [id], onDelete: Cascade)
  article   Article      @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([pathId, articleId])
  @@index([pathId])
}

model LearningPathProgress {
  id                  String       @id @default(cuid())
  userId              String
  pathId              String
  completedArticleIds String[]
  updatedAt           DateTime     @updatedAt
  path                LearningPath @relation(fields: [pathId], references: [id], onDelete: Cascade)
  user                User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, pathId])
  @@index([userId])
}

model Flashcard {
  id          String   @id @default(cuid())
  userId      String
  articleId   String?
  front       String   @db.Text
  back        String   @db.Text
  nextDue     DateTime @default(now())
  interval    Int      @default(1)
  easeFactor  Float    @default(2.5)
  repetitions Int      @default(0)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  article     Article? @relation(fields: [articleId], references: [id], onDelete: SetNull)

  @@index([userId, nextDue])
}

model QuizAttempt {
  id             String   @id @default(cuid())
  userId         String
  articleId      String
  score          Int
  totalQuestions Int
  answers        Json
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  article        Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([articleId])
}

model ArticleRead {
  id        String   @id @default(cuid())
  userId    String
  articleId String
  readAt    DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
  @@index([userId])
}

// ── v4.0: AI Embeddings ──
model ArticleEmbedding {
  id        String   @id @default(cuid())
  articleId String   @unique
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  embedding Float[]
  updatedAt DateTime @updatedAt

  @@index([articleId])
}

// ── v3.0: Article Templates ──
model ArticleTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  content     String   @db.Text
  categoryId  String?
  authorId    String?
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ── v4.3: Discovery & Navigation ──

model SmartCollection {
  id         String   @id @default(cuid())
  name       String
  query      Json     // { tags?, categoryId?, authorId?, status?, dateFrom?, dateTo? }
  userId     String
  isPublic   Boolean  @default(false)
  shareToken String?  @unique
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  articleId String
  note      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
  @@index([userId])
}

model ReadingList {
  id          String           @id @default(cuid())
  name        String
  description String?
  userId      String
  isPublic    Boolean          @default(false)
  shareToken  String           @unique @default(cuid())
  items       ReadingListItem[]
  createdAt   DateTime         @default(now())
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ReadingListItem {
  id        String      @id @default(cuid())
  listId    String
  articleId String
  order     Int
  list      ReadingList @relation(fields: [listId], references: [id], onDelete: Cascade)
  article   Article     @relation(fields: [articleId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@unique([listId, articleId])
  @@index([listId])
}

model TILPost {
  id         String    @id @default(cuid())
  userId     String
  content    String    @db.VarChar(280)
  articleId  String?
  tags       String[]
  archivedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  article    Article?  @relation(fields: [articleId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([userId])
}

// ── v4.4: Collaboration 2.0 ──

model ExpertBadge {
  id         String   @id @default(cuid())
  userId     String
  categoryId String
  grantedBy  String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId])
  @@index([categoryId])
}

model KnowledgeBounty {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  requesterId String
  claimedBy   String?
  articleId   String?
  status      String   @default("open")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  requester   User     @relation("BountiesRequested", fields: [requesterId], references: [id])
  claimer     User?    @relation("BountiesClaimed", fields: [claimedBy], references: [id])
  article     Article? @relation(fields: [articleId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([requesterId])
}

model ArticleFork {
  id                String   @id @default(cuid())
  originalArticleId String
  authorId          String
  title             String
  content           String   @db.Text
  contentRaw        String?  @db.Text
  message           String?
  status            String   @default("draft")
  reviewNote        String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  original          Article  @relation(fields: [originalArticleId], references: [id], onDelete: Cascade)
  author            User     @relation(fields: [authorId], references: [id])

  @@index([originalArticleId])
  @@index([authorId])
  @@index([status])
}

model ArticleReaction {
  id        String   @id @default(cuid())
  articleId String
  userId    String?
  sessionId String?
  reaction  String
  createdAt DateTime @default(now())
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([articleId, userId])
  @@index([articleId])
}

// v4.5 models

model IssueLink {
  id            String    @id @default(cuid())
  articleId     String
  url           String
  provider      String    // github | jira | linear
  issueId       String
  title         String?
  status        String?   // open | closed | in_progress
  lastCheckedAt DateTime?
  createdAt     DateTime  @default(now())
  article       Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
}

model EmbedToken {
  id        String   @id @default(cuid())
  articleId String
  token     String   @unique @default(cuid())
  createdAt DateTime @default(now())
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
}

// v4.6 models

model ScrollDepthLog {
  id        String   @id @default(cuid())
  articleId String
  userId    String?
  sessionId String
  depth     Int      // 0-100 percentage
  createdAt DateTime @default(now())
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
  @@index([createdAt])
}

model ReaderPathEvent {
  id        String   @id @default(cuid())
  fromSlug  String
  toSlug    String
  userId    String?
  sessionId String
  createdAt DateTime @default(now())

  @@index([fromSlug])
  @@index([createdAt])
}

model ContributorAchievement {
  id       String   @id @default(cuid())
  userId   String
  badge    String
  metadata Json?
  earnedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badge])
  @@index([userId])
}

model Scratchpad {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String   @db.Text @default("")
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  username    String?
  action      String   // e.g. "article.delete", "user.role_change", "category.delete"
  entityType  String   // "article", "category", "user", "revision"
  entityId    String?
  entityLabel String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([action])
  @@index([userId])
}
